{
  "name": "paul-arcade-launcher-tools",
  "private": true,
  "version": "0.0.0",
  "description": "Tooling for the Paul's Arcade launcher repo. The launcher itself is plain static HTML; this manifest exists only for dev tooling (Playwright-based acceptance runner).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "node tools/run-units.mjs",
    "check-sw-bump": "node tools/check-sw-bump.mjs",
    "acceptance": "node tools/acceptance.mjs",
    "p2p-acceptance": "node tools/p2p-acceptance.mjs",
    "p2p-multiseat": "node tools/p2p-multiseat-acceptance.mjs",
    "p2p-multiparty": "node tools/p2p-multiparty-acceptance.mjs",
    "p2p-reconnect": "node tools/p2p-reconnect-acceptance.mjs",
    "sync-acceptance": "node tools/sync-acceptance.mjs",
    "backup-acceptance": "node tools/backup-acceptance.mjs",
    "backup-unit": "node tools/backup-unit.mjs",
    "local-backup-acceptance": "node tools/local-backup-acceptance.mjs",
    "local-backup-unit": "node tools/local-backup-unit.mjs",
    "rendezvous-unit": "node tools/rendezvous-unit.mjs",
    "mqtt-codec-unit": "node tools/mqtt-codec-unit.mjs",
    "p2p-core-unit": "node tools/p2p-core-unit.mjs",
    "save-unit": "node tools/save-validation-unit.mjs",
    "sync-unit": "node tools/sync-unit.mjs",
    "envelope-unit": "node tools/envelope-unit.mjs",
    "user-identity-unit": "node tools/user-identity-unit.mjs",
    "user-identity-acceptance": "node tools/user-identity-acceptance.mjs",
    "p2p-crosssign": "node tools/p2p-crosssign-acceptance.mjs",
    "sdk-helpers": "node tools/sdk-helpers-acceptance.mjs",
    "store-acceptance": "node tools/store-acceptance.mjs",
    "bridge-acceptance": "node tools/bridge-acceptance.mjs",
    "ui-acceptance": "node tools/ui-acceptance.mjs",
    "export-roundtrip": "node tools/export-roundtrip-acceptance.mjs",
    "export-advanced-acceptance": "node tools/export-advanced-acceptance.mjs",
    "catalog-acceptance": "node tools/catalog-acceptance.mjs",
    "records-acceptance": "node tools/records-acceptance.mjs",
    "acceptance:pool": "node tools/acceptance.mjs --pool --serve --catalog tools/fixtures/ci-catalog.json"
  },
  "devDependencies": {
    "playwright": "^1.50.0"
  }
}
